{
  "name": "agent-ui",
  "version": "0.13.2",
  "private": true,
  "author": "krolebord",
  "description": "Simple orchestrator for CLI agents",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:static": "vite build --sourcemap && electron .",
    "build": "tsc && vite build",
    "analyze": "ANALYZE=true vite build",
    "app:dist": "pnpm build && electron-builder",
    "app:dist:mac": "pnpm build && electron-builder --mac",
    "app:dist:mac:dir": "pnpm build && electron-builder --mac dir",
    "app:install": "pnpm app:dist:mac:dir && ./scripts/install-mac-app.sh",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write .",
    "test": "vitest run",
    "extract-cursor-models": "bash scripts/extract-cursor-models.sh"
  },
  "dependencies": {
    "@dnd-kit/dom": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@orpc/client": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@orpc/tanstack-query": "^1.13.5",
    "@tanstack/react-hotkeys": "^0.2.0",
    "@tanstack/react-query": "^5.90.21",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "fix-path": "^5.0.0",
    "immer": "^11.1.4",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^0.575.0",
    "nano-spawn": "^2.0.0",
    "node-pty": "1.2.0-beta.11",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.7.3",
    "simple-git": "^3.33.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "lefthook",
      "node-pty"
    ],
    "ignoredBuiltDependencies": [
      "electron-winstaller"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "lefthook": "^2.1.1",
    "rollup-plugin-visualizer": "^7.0.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.2",
    "vite": "^7.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.0"
  }
}
